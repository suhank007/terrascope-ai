# Copy to .env.local and fill in what you need. Nothing here is required to
# run the app — the globe, earthquakes, weather, and air quality all work
# immediately with zero configuration. Each block below unlocks one optional
# feature; skip any you don't need.

# Wildfires — free, instant signup at firms.modaps.eosdis.nasa.gov/api/map_key
NASA_FIRMS_MAP_KEY=

# AI Copilot chat — get a key at console.anthropic.com
ANTHROPIC_API_KEY=

# Accounts + saved views — create a free project at supabase.com, then copy
# these three values from Project Settings -> API. Also run the SQL in
# supabase/migrations/0001_saved_views.sql once, in your project's SQL Editor.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SECRET_KEY=
