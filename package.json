    "@tanstack/react-query": "^5.101.2",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.23.0",
    "clsx": "^2.1.1",
    "tailwind-merge": "^3.6.0",
    "geist": "^1.7.0",
    "class-variance-authority": "^0.7.1",
    "zod": "^4.4.3",
    "server-only": "^0.0.1",
    "@anthropic-ai/sdk": "^0.110.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.110.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
