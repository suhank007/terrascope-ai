{
  "name": "terrascope-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Real-time global intelligence platform — a live 3D globe streaming earthquakes, weather, flights, wildfires, and air quality, with an AI copilot that answers questions against the live data.",
  "homepage": "https://terrascope-ai.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/suhank007/terrascope-ai"
