  "keywords": [
    "cesium",
    "3d-globe",
    "nextjs",
    "react",
    "typescript",
    "real-time-data",
    "geospatial",
    "claude-ai"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
